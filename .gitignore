# ─── Local AI tooling state (per-user, never shared) ─────────────────
.claude/
.agents/
.mcp.json
.obsidian/

# ─── Node / Next.js builds (apply at any depth) ──────────────────────
node_modules/
.next/
out/
build/
coverage/

# ─── Env files — real secrets never committed ────────────────────────
.env
.env.*
!.env.local.example
!.env.example

# ─── Logs / debug artifacts ──────────────────────────────────────────
*.log
debug-*.png

# ─── Editor / OS / build cache ───────────────────────────────────────
.DS_Store
.vercel/
*.tsbuildinfo
next-env.d.ts

# ─── Project scratch / dev fixtures ──────────────────────────────────
scratch/

# Stray nested folder from a prior copy; safe to delete on disk
sunday-tally/sunday-tally/
