# Copy this to .env.local and fill in your values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (billing) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...                  # $22/mo recurring price id
NEXT_PUBLIC_APP_URL=http://localhost:3000  # absolute base for checkout return URLs

# --- Anthropic (AI import + analytics chat) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Resend (transactional email) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Sunday Tally <noreply@yourdomain.com>

# --- Cron ---
CRON_SECRET=change-me                      # shared bearer for /api/cron endpoints
